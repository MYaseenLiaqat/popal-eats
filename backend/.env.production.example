# Production environment template — copy values to Railway/Render dashboard.
# Do NOT commit real secrets.

DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SECRET_KEY=generate-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DEBUG=false
LOG_LEVEL=INFO

# Comma-separated origins: Flutter web host, admin panel, etc.
CORS_ORIGINS=https://your-frontend.web.app,https://api.popaleats.com
RATE_LIMIT_DEFAULT=200/minute

# Redis (Railway Redis plugin or Upstash)
REDIS_URL=redis://default:PASSWORD@HOST:6379
RQ_QUEUE_NAME=popal_eats
PROCESS_REVIEWS_INLINE=false

OCR_ENGINE=tesseract
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

ENABLE_HF_SENTIMENT=false
ENABLE_MARIAN_TRANSLATION=false

# Firebase Web OAuth client ID (client_type 3) — must match Flutter GOOGLE_WEB_CLIENT_ID
GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
